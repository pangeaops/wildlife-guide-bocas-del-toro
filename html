<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BOCAS DEL TORO | COMPLETE WILDLIFE ARCHIVE</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;800&family=Space+Grotesk:wght@300;500;700&family=JetBrains+Mono&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root {
            --primary: #10b981;
            --secondary: #3b82f6;
            --accent: #f59e0b;
            --danger: #ef4444;
            --bg: #030712;
        }
        body { 
            font-family: 'Inter', sans-serif; 
            background-color: var(--bg); 
            color: #cbd5e1;
            scroll-behavior: smooth;
            line-height: 1.6;
        }
        h1, h2, h3, .heading { font-family: 'Space Grotesk', sans-serif; color: #f8fafc; }
        .mono { font-family: 'JetBrains Mono', monospace; }
        .glass-card { 
            background: rgba(255, 255, 255, 0.02); 
            backdrop-filter: blur(12px); 
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .glass-card:hover { border-color: var(--primary); transform: translateY(-2px); }
        .section-tag {
            font-size: 0.75rem;
            font-weight: 800;
            letter-spacing: 0.25em;
            text-transform: uppercase;
            padding: 6px 16px;
            border-radius: 99px;
            background: rgba(16, 185, 129, 0.1);
            color: var(--primary);
            margin-bottom: 1.5rem;
            display: inline-block;
        }
        .highlight-text { color: #ffffff; font-weight: 600; }
        .scientific { font-style: italic; color: #94a3b8; font-size: 0.9em; }
        .species-pill {
            background: rgba(255,255,255,0.05);
            padding: 6px 12px;
            border-radius: 8px;
            font-size: 0.85rem;
            border: 1px solid rgba(255,255,255,0.1);
            color: #e2e8f0;
        }
    </style>
</head>
<body class="selection:bg-emerald-500/30">

    <!-- NAVIGATION -->
    <nav class="fixed top-0 w-full z-50 border-b border-white/5 bg-black/80 backdrop-blur-lg">
        <div class="max-w-[1400px] mx-auto px-6 h-20 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-8 h-8 bg-emerald-500 rounded-md shadow-[0_0_15px_rgba(16,185,129,0.4)]"></div>
                <span class="font-bold tracking-tighter text-xl text-white underline decoration-emerald-500 underline-offset-4">BOCAS.BIO ARCHIVE</span>
            </div>
            <div class="hidden lg:flex gap-8 text-[11px] font-bold uppercase tracking-widest text-slate-400">
                <a href="#climate" class="hover:text-emerald-400 transition-colors">Climate</a>
                <a href="#calendar" class="hover:text-emerald-400 transition-colors">Calendar</a>
                <a href="#marine" class="hover:text-emerald-400 transition-colors">Marine</a>
                <a href="#birds" class="hover:text-emerald-400 transition-colors">Birds</a>
                <a href="#mammals" class="hover:text-emerald-400 transition-colors">Mammals</a>
                <a href="#herps" class="hover:text-emerald-400 transition-colors">Reptiles</a>
                <a href="#flora" class="hover:text-emerald-400 transition-colors">Flora</a>
            </div>
        </div>
    </nav>

    <main class="max-w-[1400px] mx-auto px-6 pt-40 pb-20">
        
        <!-- HEADER -->
        <header class="mb-32">
            <h1 class="text-7xl md:text-9xl font-bold tracking-tighter leading-[0.9] mb-10">
                BOCAS DEL TORO <br><span class="text-emerald-500 italic">BIODIVERSITY.</span>
            </h1>
            <p class="max-w-3xl text-2xl text-slate-400 font-light leading-relaxed">
                A comprehensive seasonal encyclopedia of Panama's Caribbean archipelago. Expert-level data for marine, avian, and terrestrial ecosystems.
            </p>
        </header>

        <!-- CLIMATE -->
        <section id="climate" class="mb-48 scroll-mt-28">
            <div class="section-tag">Climate Dynamics</div>
            <h2 class="text-5xl font-bold mb-16 tracking-tight">Weather & Seasonal Patterns</h2>
            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
                <div class="glass-card p-8 rounded-3xl border-t-4 border-emerald-500">
                    <h3 class="font-bold uppercase text-xs mb-3 text-emerald-500 tracking-widest">Primary Dry</h3>
                    <p class="text-lg text-white font-medium italic">Dec – Apr</p>
                    <p class="text-sm mt-4 text-slate-400 leading-relaxed">Predominant trade winds from the NE. Peak underwater visibility (20m+).</p>
                </div>
                <div class="glass-card p-8 rounded-3xl border-t-4 border-amber-500">
                    <h3 class="font-bold uppercase text-xs mb-3 text-amber-500 tracking-widest">Secondary Dry</h3>
                    <p class="text-lg text-white font-medium italic">Sep – Nov</p>
                    <p class="text-sm mt-4 text-slate-400 leading-relaxed">The "Bocas Summer." Mirror-flat seas and highest sun exposure.</p>
                </div>
                <div class="glass-card p-8 rounded-3xl border-t-4 border-blue-500">
                    <h3 class="font-bold uppercase text-xs mb-3 text-blue-500 tracking-widest">Rainy Peak</h3>
                    <p class="text-lg text-white font-medium italic">May – Nov</p>
                    <p class="text-sm mt-4 text-slate-400 leading-relaxed">Afternoon tropical downpours. High humidity (avg 90%).</p>
                </div>
                <div class="glass-card p-8 rounded-3xl border-t-4 border-slate-500">
                    <h3 class="font-bold uppercase text-xs mb-3 text-slate-400 tracking-widest">Environmental Constants</h3>
                    <p class="text-lg text-white font-medium italic">Year-Round</p>
                    <p class="text-sm mt-4 text-slate-400 leading-relaxed">Stable 27-30°C (80-86°F). Prevailing humid tropical rainforest climate.</p>
                </div>
            </div>
        </section>

        <!-- CALENDAR -->
        <section id="calendar" class="mb-48 scroll-mt-28">
            <div class="section-tag">Seasonal Calendar</div>
            <h2 class="text-5xl font-bold mb-16 tracking-tight">Temporal Wildlife Log</h2>
            
            <div class="space-y-16">
                <!-- DEC-APR -->
                <div class="glass-card p-12 rounded-[2.5rem]">
                    <h3 class="text-3xl font-bold text-emerald-500 mb-10 flex items-center gap-4">
                        <i data-lucide="sun" class="w-8 h-8"></i> DECEMBER – APRIL
                    </h3>
                    <div class="grid md:grid-cols-3 gap-12">
                        <div>
                            <h4 class="text-xs font-black uppercase text-slate-500 mb-6 tracking-[0.2em]">Marine Fauna</h4>
                            <ul class="text-base space-y-4 text-slate-300">
                                <li><span class="highlight-text">Humpback Whales:</span> Northern Atlantic pods (Dec-Feb).</li>
                                <li><span class="highlight-text">Whale Sharks:</span> Occasional sightings peak Jan-Mar.</li>
                                <li><span class="highlight-text">Reef Exploration:</span> Optimal for remote offshore sites.</li>
                            </ul>
                        </div>
                        <div>
                            <h4 class="text-xs font-black uppercase text-slate-500 mb-6 tracking-[0.2em]">Terrestrial Cycles</h4>
                            <ul class="text-base space-y-4 text-slate-300">
                                <li><span class="highlight-text">Avian Nesting:</span> High activity in primary forests.</li>
                                <li><span class="highlight-text">Mammals:</span> Primates highly vocal during early morning hours.</li>
                                <li><span class="highlight-text">Sea Turtles:</span> Leatherback nesting starts in March.</li>
                            </ul>
                        </div>
                        <div>
                            <h4 class="text-xs font-black uppercase text-slate-500 mb-6 tracking-[0.2em]">Agriculture</h4>
                            <ul class="text-base space-y-4 text-slate-300">
                                <li><span class="highlight-text">Cacao Harvest:</span> Peak pod ripening and traditional drying.</li>
                                <li><span class="highlight-text">Tropical Fruits:</span> Mango and Citrus peak production.</li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- MAY-AUG -->
                <div class="glass-card p-12 rounded-[2.5rem]">
                    <h3 class="text-3xl font-bold text-blue-500 mb-10 flex items-center gap-4">
                        <i data-lucide="droplets" class="w-8 h-8"></i> MAY – AUGUST
                    </h3>
                    <div class="grid md:grid-cols-3 gap-12">
                        <div class="md:col-span-1">
                            <h4 class="text-xs font-black uppercase text-slate-500 mb-6 tracking-[0.2em]">Nesting Peak</h4>
                            <p class="text-xl text-white font-bold mb-3 tracking-tight">LEATHERBACK TURTLE SEASON</p>
                            <p class="text-base text-slate-400 leading-relaxed">March – June (Peak in April/May). Nesting concentrated at Playa Bluff and Soropta Beach. Large clutches of 80-100 eggs.</p>
                        </div>
                        <div class="md:col-span-1">
                            <h4 class="text-xs font-black uppercase text-slate-500 mb-6 tracking-[0.2em]">Herpetology</h4>
                            <p class="text-base text-slate-300 leading-relaxed">Increased rainfall triggers explosive breeding of <span class="highlight-text">Glass Frogs</span> and <span class="highlight-text">Red-eyed Tree Frogs</span> across the archipelago.</p>
                        </div>
                        <div class="md:col-span-1">
                            <h4 class="text-xs font-black uppercase text-slate-500 mb-6 tracking-[0.2em]">In-Shore Marine</h4>
                            <p class="text-base text-slate-300 leading-relaxed">Nutrient-rich runoff triggers plankton blooms, attracting <span class="highlight-text">Manta Rays</span> into the bay channels.</p>
                        </div>
                    </div>
                </div>

                <!-- SEP-NOV -->
                <div class="glass-card p-12 rounded-[2.5rem] border border-emerald-500/20">
                    <h3 class="text-3xl font-bold text-amber-500 mb-10 flex items-center gap-4">
                        <i data-lucide="compass" class="w-8 h-8"></i> SEPTEMBER – NOVEMBER
                    </h3>
                    <div class="grid md:grid-cols-3 gap-12">
                        <div>
                            <h4 class="text-xs font-black uppercase text-slate-500 mb-6 tracking-[0.2em]">Deep Diving</h4>
                            <p class="text-base text-slate-300 leading-relaxed"><span class="highlight-text italic">Tiger Rock and Polo Channel</span> are safest and clearest during this calm-sea window.</p>
                        </div>
                        <div>
                            <h4 class="text-xs font-black uppercase text-slate-500 mb-6 tracking-[0.2em]">The Great Migration</h4>
                            <p class="text-base text-slate-300 leading-relaxed"><span class="highlight-text italic">Raptor Corridor:</span> Over 2 million Vultures and Hawks pass through the Talamanca corridor.</p>
                        </div>
                        <div>
                            <h4 class="text-xs font-black uppercase text-slate-500 mb-6 tracking-[0.2em]">Sea Turtle Hatchlings</h4>
                            <p class="text-base text-slate-300 leading-relaxed">Hatchlings emerge through January. <span class="highlight-text">Hawksbills</span> nesting in Bastimentos National Park.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- MARINE -->
        <section id="marine" class="mb-48 scroll-mt-28">
            <div class="section-tag">Marine Ecosystems</div>
            <h2 class="text-5xl font-bold mb-16 tracking-tight">Coral Reefs, Mangroves & Pelagics</h2>
            
            <div class="grid lg:grid-cols-3 gap-10">
                <div class="lg:col-span-2 glass-card p-12 rounded-[2.5rem]">
                    <h3 class="text-3xl font-bold mb-10 italic tracking-tight">Coral Reef Index (70+ Species)</h3>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
                        <div class="space-y-6">
                            <p class="text-xs font-bold text-emerald-500 uppercase tracking-widest">Keystone Species</p>
                            <div class="space-y-4">
                                <p class="text-base"><span class="highlight-text">Elkhorn Coral</span><br><span class="scientific">Acropora palmata</span></p>
                                <p class="text-base"><span class="highlight-text">Staghorn Coral</span><br><span class="scientific">Acropora cervicornis</span></p>
                            </div>
                        </div>
                        <div class="space-y-6">
                            <p class="text-xs font-bold text-emerald-500 uppercase tracking-widest">Massive Formations</p>
                            <div class="space-y-4">
                                <p class="text-base"><span class="highlight-text">Brain Coral</span><br><span class="scientific">Diplora spp.</span></p>
                                <p class="text-base"><span class="highlight-text">Lettuce Coral</span><br><span class="scientific">Agaricia spp.</span></p>
                            </div>
                        </div>
                        <div class="space-y-6">
                            <p class="text-xs font-bold text-emerald-500 uppercase tracking-widest">Gorgonians</p>
                            <div class="space-y-4">
                                <p class="text-base"><span class="highlight-text">Sea Fans</span><br><span class="scientific">Gorgonia spp.</span></p>
                                <p class="text-base"><span class="highlight-text">Finger Coral</span><br><span class="scientific">Porites spp.</span></p>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="glass-card p-12 rounded-[2.5rem]">
                    <h3 class="text-3xl font-bold mb-8 italic tracking-tight">Mangroves</h3>
                    <ul class="text-base space-y-5 text-slate-400">
                        <li>• <span class="highlight-text">Red (Rhizophora mangle):</span> Distinct prop roots; critical reef nursery.</li>
                        <li>• <span class="highlight-text">Black (Avicennia):</span> Known for "snorkel" roots (pneumatophores).</li>
                        <li>• <span class="highlight-text">White & Buttonwood:</span> Landward stabilizers and salt filters.</li>
                    </ul>
                </div>

                <div class="lg:col-span-3 glass-card p-12 rounded-[2.5rem]">
                    <h3 class="text-2xl font-bold mb-8 italic tracking-tight">Reef Fish & Pelagics Census (200+ Species)</h3>
                    <div class="flex flex-wrap gap-3">
                        <span class="species-pill">Parrotfish (Princess/Queen)</span>
                        <span class="species-pill">French Angelfish</span>
                        <span class="species-pill">Trumpetfish</span>
                        <span class="species-pill">Great Barracuda</span>
                        <span class="species-pill">Moray Eels (Green/Spotted)</span>
                        <span class="species-pill">Spotted Eagle Rays</span>
                        <span class="species-pill">Nurse Sharks</span>
                        <span class="species-pill">Bottlenose Dolphins</span>
                        <span class="species-pill">Seahorses</span>
                        <span class="species-pill">Manatees (Changuinola River)</span>
                        <span class="species-pill">Southern Stingrays</span>
                        <span class="species-pill">Lionfish (Invasive)</span>
                    </div>
                </div>
            </div>
        </section>

        <!-- BIRDS -->
        <section id="birds" class="mb-48 scroll-mt-28">
            <div class="section-tag">Avian Repository</div>
            <h2 class="text-5xl font-bold mb-16 tracking-tight">The 700+ Species Census</h2>
            <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
                <div class="glass-card p-10 rounded-3xl">
                    <h4 class="text-emerald-500 font-bold text-xs uppercase mb-8 tracking-[0.2em] italic">Forest Residents</h4>
                    <ul class="text-base space-y-6">
                        <li><span class="highlight-text">Keel-billed Toucan</span><br><span class="scientific">Ramphastos sulfuratus</span></li>
                        <li><span class="highlight-text">Montezuma Oropendola</span><br><span class="text-sm text-slate-400">Famous for colonial hanging nests.</span></li>
                        <li><span class="highlight-text">Snowy Cotinga</span><br><span class="text-sm text-slate-400">High-canopy ghostly white resident.</span></li>
                        <li><span class="highlight-text">Three-wattled Bellbird</span><br><span class="text-sm text-slate-400">Extremely loud, metallic calls.</span></li>
                    </ul>
                </div>
                <div class="glass-card p-10 rounded-3xl">
                    <h4 class="text-blue-500 font-bold text-xs uppercase mb-8 tracking-[0.2em] italic">Seabirds & Waders</h4>
                    <ul class="text-base space-y-6">
                        <li><span class="highlight-text">Red-billed Tropicbird</span><br><span class="text-sm text-slate-400">Nests on Isla Pájaros cliffs.</span></li>
                        <li><span class="highlight-text">Roseate Spoonbill</span><br><span class="text-sm text-slate-400">Vibrant pink wader in mangroves.</span></li>
                        <li><span class="highlight-text">Brown Booby</span><br><span class="text-sm text-slate-400">Primary Isla Pájaros colony.</span></li>
                        <li><span class="highlight-text">Northern Jacana</span><br><span class="text-sm text-slate-400">"Lily-walker" with long toes.</span></li>
                    </ul>
                </div>
                <div class="glass-card p-10 rounded-3xl">
                    <h4 class="text-amber-500 font-bold text-xs uppercase mb-8 tracking-[0.2em] italic">Migratory Warblers</h4>
                    <ul class="text-base space-y-6">
                        <li><span class="highlight-text">Prothonotary Warbler</span><br><span class="text-sm text-slate-400">Golden swamp-dweller.</span></li>
                        <li><span class="highlight-text">Blackburnian Warbler</span><br><span class="text-sm text-slate-400">Bright orange-throated visitor.</span></li>
                        <li><span class="highlight-text">Golden-winged</span><br><span class="text-sm text-slate-400">Critically endangered visitor.</span></li>
                    </ul>
                </div>
                <div class="glass-card p-10 rounded-3xl">
                    <h4 class="text-red-500 font-bold text-xs uppercase mb-8 tracking-[0.2em] italic">Raptors</h4>
                    <ul class="text-base space-y-6">
                        <li><span class="highlight-text">Turkey Vulture</span><br><span class="text-sm text-slate-400">Millions in seasonal flight.</span></li>
                        <li><span class="highlight-text">Broad-winged Hawk</span><br><span class="text-sm text-slate-400">Forming massive thermal "kettles."</span></li>
                        <li><span class="highlight-text">Swallow-tailed Kite</span><br><span class="text-sm text-slate-400">Arguably the most elegant aerialist.</span></li>
                    </ul>
                </div>
            </div>
        </section>

        <!-- MAMMALS -->
        <section id="mammals" class="mb-48 scroll-mt-28">
            <div class="section-tag">Mammalian Fauna</div>
            <h2 class="text-5xl font-bold mb-16 tracking-tight">Iconic Sloths & Primates</h2>
            
            <div class="grid lg:grid-cols-3 gap-10 mb-10">
                <div class="lg:col-span-2 glass-card p-12 rounded-[2.5rem] border-l-[10px] border-l-red-500">
                    <h3 class="text-4xl font-bold mb-6 italic uppercase tracking-tighter">Pygmy Three-Toed Sloth</h3>
                    <p class="mono text-xs text-red-500 mb-8 font-bold uppercase tracking-[0.3em]">Critically Endangered // Isla Escudo de Veraguas</p>
                    <p class="text-lg text-slate-300 leading-relaxed mb-8">
                        <span class="scientific italic font-bold text-white">Bradypus pygmaeus:</span> The world's smallest sloth, found only on a single island in the Bocas archipelago. Genetically isolated, it is 20% smaller than mainland cousins and uniquely adapted to swimming through saltwater mangrove channels.
                    </p>
                    <div class="grid md:grid-cols-2 gap-6 text-base">
                        <div class="p-6 bg-white/5 rounded-2xl border border-white/5"><span class="highlight-text">Habitat:</span> Red Mangrove forests exclusively.</div>
                        <div class="p-6 bg-white/5 rounded-2xl border border-white/5"><span class="highlight-text">Primary Threat:</span> Extreme habitat isolation.</div>
                    </div>
                </div>
                <div class="glass-card p-12 rounded-[2.5rem]">
                    <h4 class="font-bold text-xs uppercase mb-8 text-emerald-500 tracking-widest italic">Common Residents</h4>
                    <ul class="text-base space-y-6 text-slate-400">
                        <li>• <span class="highlight-text">Two-toed Sloth:</span> Nocturnal, often found in almond trees.</li>
                        <li>• <span class="highlight-text">Three-toed Sloth:</span> Diurnal, the famous "smiling" icon.</li>
                        <li>• <span class="highlight-text">Mantled Howler:</span> Their dawn calls carry for miles.</li>
                        <li>• <span class="highlight-text">White-faced Capuchin:</span> Highly social and intelligent.</li>
                    </ul>
                </div>
            </div>

            <div class="glass-card p-12 rounded-[2.5rem]">
                <h3 class="text-2xl font-bold mb-10 italic tracking-tight">Terrestrial & Arboreal Census</h3>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-y-6 gap-x-12 text-[11px] text-slate-500 uppercase font-black tracking-widest">
                    <span>Spider Monkey</span>
                    <span>Panamanian Night Monkey</span>
                    <span>White-nosed Coati</span>
                    <span>Kinkajou</span>
                    <span>Tayra</span>
                    <span>Jaguarundi</span>
                    <span>Agouti</span>
                    <span>Lowland Paca</span>
                    <span>Porcupine</span>
                    <span>Armadillo</span>
                    <span>Silky Anteater</span>
                    <span>Northern Tamandua</span>
                </div>
            </div>
        </section>

        <!-- HERPETOLOGY -->
        <section id="herps" class="mb-48 scroll-mt-28">
            <div class="section-tag">Herpetology</div>
            <h2 class="text-5xl font-bold mb-16 tracking-tight">Poison Dart Frogs & Reptiles</h2>
            <div class="grid lg:grid-cols-2 gap-10">
                <div class="glass-card p-12 rounded-[2.5rem] border-l-[10px] border-l-emerald-500">
                    <h3 class="text-3xl font-bold mb-8 italic uppercase tracking-tight">Strawberry Poison Frog</h3>
                    <p class="scientific text-base mb-6">Oophaga pumilio</p>
                    <p class="text-base text-slate-400 leading-relaxed italic">
                        Renowned for extreme island-specific phenotypic variation:
                        <br><br>• <span class="highlight-text">Isla Colón:</span> Lime green w/ black spots.
                        <br>• <span class="highlight-text">Bastimentos:</span> Red, orange, or white "Cemetery" morphs.
                        <br>• <span class="highlight-text">Mainland:</span> Traditional red body w/ blue "jeans" legs.
                    </p>
                </div>
                <div class="glass-card p-12 rounded-[2.5rem]">
                    <h3 class="text-3xl font-bold mb-10 italic uppercase tracking-tight">Additional Species</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
                        <ul class="text-base space-y-4 text-slate-400">
                            <li>• <span class="highlight-text">Red-eyed Tree Frog</span></li>
                            <li>• <span class="highlight-text">Glass Frogs</span></li>
                            <li>• <span class="highlight-text">Harlequin Tree Frog</span></li>
                            <li>• <span class="highlight-text">Sylvia's Tree Frog</span></li>
                        </ul>
                        <ul class="text-base space-y-4 text-slate-400">
                            <li>• <span class="highlight-text">Boa Constrictor</span></li>
                            <li>• <span class="highlight-text">Green Parrot Snake</span></li>
                            <li>• <span class="highlight-text">Basilisk Lizard</span></li>
                            <li>• <span class="highlight-text">Green Iguana</span></li>
                        </ul>
                    </div>
                </div>
            </div>
        </section>

        <!-- FLORA -->
        <section id="flora" class="mb-48 scroll-mt-28">
            <div class="section-tag">Botanical Archive</div>
            <h2 class="text-5xl font-bold mb-16 tracking-tight">Canopy Giants & Agriculture</h2>
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 mb-16">
                <div class="glass-card p-10 rounded-3xl">
                    <h4 class="text-xs font-bold uppercase text-slate-500 mb-8 tracking-widest">Emergent Trees</h4>
                    <ul class="text-base space-y-6">
                        <li>• <span class="highlight-text">Kapok (Ceiba):</span> Iconic buttressed trunks to 200ft.</li>
